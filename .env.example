# ===== EMAIL CONFIGURATION (Gmail SMTP) =====
# Step 1: Go to https://myaccount.google.com/apppasswords
# Step 2: Select Mail > Windows Computer
# Step 3: Copy the 16-char password and paste below
# Step 4: Rename this to .env and fill in your values

EMAIL_SENDER="your-email@gmail.com"
EMAIL_PASSWORD="your-16-char-app-password"
EMAIL_RECEIVER="your-email@gmail.com"

# ===== SMS CONFIGURATION (Twilio) - Optional =====
# Step 1: Go to https://www.twilio.com/console
# Step 2: Copy Account SID, Auth Token, and your Twilio phone number

TWILIO_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token_here"
TWILIO_PHONE_NUMBER="+1234567890"
RECEIVER_PHONE_NUMBER="+919876543210"

# ===== ALERT CONFIGURATION =====
# EXPIRY_LEAD_DAYS: Alert medicines expiring within N days (default: 180 = 6 months)
EXPIRY_LEAD_DAYS=180

# ===== PRODUCTION SETTINGS =====
FLASK_ENV=production
DEBUG=False
